ENVIRONMENT=local
APP_NAME=FastAPI App
APP_VERSION=0.1.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=postgres

# Database Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Auth
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Webhook used for testing events.
WEBHOOK_URL=https://webhook.site/your-webhook-id
